# -------------------------
# Database & storage
# -------------------------
# SQLite local DB (default). Keep as-is for local dev.
DATABASE_URL=sqlite:///./rag_chatbot_policy.db

# Folder where your PDFs live (relative to project root)
PDFS_FOLDER=data/pdfs

# -------------------------
# App / auth
# -------------------------
# JWT secret — change to a long random value for production
SECRET_KEY=replace_this_with_a_long_random_secret_value

# Algorithm and token expiry (minutes)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -------------------------
# RAG / embedding / LLM config
# -------------------------
# Mode: "mock" (default) or "bedrock"
RAG_MODE=mock

# If you want to use Bedrock set USE_BEDROCK to true and fill AWS creds below
USE_BEDROCK=false

# If using Bedrock, the model name (they asked sonet3.5)
BEDROCK_MODEL_NAME=sonet3.5

# Embedding dimension for mock embeddings (adjust if you change real embeddings)
EMBED_DIM=128

# -------------------------
# AWS / Bedrock (optional)
# -------------------------
# Only needed if USE_BEDROCK=true
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -------------------------
# Misc / development
# -------------------------
# Set to "true" to force reindex of PDFs on startup (dangerous on prod)
RAG_REINIT=false
